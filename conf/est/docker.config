timeline.overwrite = true
dag.overwrite = true
report.overwrite = true
nextflow.preview.output = true

docker.enabled = true

process {
    cpus = 1
    memory = 2.GB
    container = 'enzymefunctioninitiative/efi-est:latest'
    containerOptions = "-v $projectDir:$projectDir -v $projectDir/../../:$projectDir/../../ -v $EFI_DATA_DIR:$EFI_DATA_DIR"

    withName: blastreduce {
        cpus = 1
        memory = 16.GB
    }

    withName: visualize {
        cpus = 2
        memory = 8.GB
    }
}
